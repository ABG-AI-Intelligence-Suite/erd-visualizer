# AEP API credentials — set these for auto-fetch on page load.
# Copy this file to .env and fill in your values. The app will connect and load
# your org's ERD graph automatically when all required vars are set.
# DO NOT commit .env to git — it is excluded via .gitignore.
#
# Required (all three must be set for auto-fetch):
AEP_API_KEY=your-api-key
AEP_ORG_ID=your-org-id@AdobeOrg
AEP_BEARER_TOKEN=ey...
#
# Optional (defaults to prod if omitted):
AEP_SANDBOX=prod
